  font-family: var(--sans);
  font-size: 0.8rem;
  color: var(--muted);
  display: block;
  margin-bottom: 0.75rem;
}
.role-sub {
  font-family: var(--mono);
  font-size: 0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 0.75rem;
  margin-bottom: 0.4rem;
}
.prior-roles {
  margin-bottom: 0.75rem;
}
.prior-roles .role-title {
  margin-bottom: 0;
}

/* Lists */
.bullet-list {
