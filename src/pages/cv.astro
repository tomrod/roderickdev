  position: relative;
  color: var(--text);
}
.bullet-list li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--muted);
}

/* Publications */
.pub-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.pub-list li {
  font-family: var(--serif);
  font-size: 0.88rem;
  line-height: 1.7;
  padding-left: 1.25rem;
