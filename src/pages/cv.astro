  color: var(--text);
  margin-bottom: 0.4rem;
}
.contact-line {
  font-family: var(--sans);
  font-size: 0.8rem;
  color: var(--muted);
  margin-bottom: 3rem;
}

/* Sections */
.cv-section {
  margin-bottom: 3rem;
}
.section-head {
  font-family: var(--mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  border-bottom: 1px solid var(--rule);
