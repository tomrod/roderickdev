---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const byYear: Record<number, typeof posts> = {};
for (const post of posts) {
  const year = post.data.date.getFullYear();
  (byYear[year] ??= []).push(post);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))].sort();

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Base title="Writing -- Roderick.Dev" activeNav="writing">
  <div class="content-pad">
    <span class="page-label">Writing</span>

    <div class="filter-bar" id="filterBar">
      <button class="filter-chip active" data-tag="all">All</button>
      {categories.map(cat => (
        <button class="filter-chip" data-tag={cat}>{cat}</button>
      ))}
    </div>

    {years.map(year => (
      <div class="year-group" data-year={year}>
        <span class="year-label">{year}</span>
        {byYear[year].map(post => (
          <div class="post-row" data-tag={post.data.category ?? ''}>
            <span class="post-date">{fmtDate(post.data.date)}</span>
            <div class="post-body">
              {post.data.category && (
                <span class="post-tag">{post.data.category}</span>
              )}
              <a class="post-title-link" href={`/writing/${post.id.replace(/\.md$/, '')}/`}>
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</Base>

<script>
  const bar = document.getElementById('filterBar');
  bar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-chip') as HTMLElement | null;
    if (!btn) return;
    const tag = btn.dataset.tag ?? 'all';
    bar.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll<HTMLElement>('.post-row').forEach(row => {
      row.style.display = (tag === 'all' || row.dataset.tag === tag) ? 'grid' : 'none';
    });
  });
</script>

<style>
.page-label {
  font-family: var(--mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 2rem;
  display: block;
}
.filter-bar {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--rule);
}
.filter-chip {
  font-family: var(--mono);
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  padding: 0.3rem 0.65rem;
  border: 1px solid var(--rule);
  background: none;
  color: var(--muted);
  border-radius: 2px;
  cursor: pointer;
  transition: all 0.12s;
}
.filter-chip:hover { border-color: var(--muted); color: var(--text); }
.filter-chip.active { border-color: var(--accent); color: var(--accent); background: var(--accent-bg); }

.year-group { margin-bottom: 3rem; }
.year-label {
  font-family: var(--mono);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  color: var(--muted);
  margin-bottom: 1rem;
  display: block;
}
.post-row {
  display: grid;
  grid-template-columns: 90px 1fr;
  border-top: 1px solid var(--rule);
  padding: 1rem 0;
  align-items: baseline;
}
.post-row:last-child { border-bottom: 1px solid var(--rule); }
.post-date {
  font-family: var(--mono);
  font-size: 0.62rem;
  color: var(--muted);
  padding-top: 0.15rem;
}
.post-tag {
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.06em;
  color: var(--accent);
  display: inline-block;
  margin-bottom: 0.3rem;
}
</style>
