---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'home' | 'writing' | 'about' | 'cv';
}

const {
  title,
  description = 'Thomas Roderick, PhD -- economist and AI systems practitioner writing on applied machine learning, causal inference, and AI governance.',
  activeNav,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  >
  <!-- Prevent FOUC: apply theme before first paint -->
  <script is:inline>
    (function () {
      var saved = localStorage.getItem('rd-theme');
      var preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', saved || preferred);
    })();
  </script>
</head>
<body>

<nav class="sidebar">
  <a href="/" class="site-name">roderick<span>.</span>dev</a>
  <span class="site-tagline">Thomas Roderick, PhD</span>

  <div class="nav-section">
    <span class="nav-label">pages</span>
    <ul class="nav-links">
      <li><a href="/" class={activeNav === 'home' ? 'active' : ''}>Home</a></li>
      <li><a href="/writing/" class={activeNav === 'writing' ? 'active' : ''}>Writing</a></li>
      <li><a href="/about/" class={activeNav === 'about' ? 'active' : ''}>About</a></li>
      <li><a href="/cv/" class={activeNav === 'cv' ? 'active' : ''}>CV</a></li>
    </ul>
  </div>

  <div class="nav-section">
    <span class="nav-label">topics</span>
    <ul class="nav-links">
      <li><a href="/writing/#causal-inference">Causal inference</a></li>
      <li><a href="/writing/#ai-governance">AI governance</a></li>
      <li><a href="/writing/#applied-ml">Applied ML</a></li>
      <li><a href="/writing/#econometrics">Econometrics</a></li>
    </ul>
  </div>

  <div class="sidebar-footer">
    <button class="theme-toggle" id="themeToggle">&#9680; light / dark</button>
    <div class="sidebar-footer-text">
      v0.3.0 · 2025<br>
      &copy; Thomas Roderick
    </div>
  </div>
</nav>

<main class="main">
  <slot />
</main>

<script>
  const toggle = document.getElementById('themeToggle');
  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('rd-theme', next);
  });
</script>

</body>
</html>
